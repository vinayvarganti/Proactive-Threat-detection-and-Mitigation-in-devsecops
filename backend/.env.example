# Server Configuration
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# MongoDB Configuration
# Local MongoDB: mongodb://localhost:27017/devsecops-platform
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/devsecops-platform
MONGODB_URI=mongodb://localhost:27017/devsecops-platform

# GitHub OAuth Configuration
# Create OAuth App at: https://github.com/settings/developers
# Homepage URL: http://localhost:5173
# Callback URL: http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/api/auth/github/callback

# Gemini AI Configuration
# Get API key from: https://makersuite.google.com/app/apikey
# Model used: gemini-1.5-flash (with gemini-1.5-flash-8b as fallback)
# Optional: Override model with GEMINI_MODEL=gemini-1.5-flash
GEMINI_API_KEY=your_gemini_api_key

# Security Configuration
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes)
TOKEN_ENCRYPTION_KEY=your_64_character_hex_encryption_key_here

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Should be 128+ characters
SESSION_SECRET=your_128_character_hex_session_secret_here

# Rate Limiting Configuration
# Maximum scans per time window
SCAN_RATE_LIMIT=10
# Time window in hours
SCAN_RATE_WINDOW_HOURS=1

# Scanner Configuration
# Set to 'true' to use mock scanners when tools are not installed
MOCK_SCANNERS=false

# Scanner Paths (optional - leave blank to use PATH)
# Gitleaks: Absolute path to gitleaks executable
GITLEAKS_PATH=
# Semgrep: Leave blank to use system PATH
SEMGREP_PATH=semgrep
# Trivy: Leave blank to use system PATH
TRIVY_PATH=trivy
